---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Image } from 'astro:assets';
import defaultHeroImage from '../assets/blog-placeholder-1.jpg';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [lead, ...rest] = allPosts;
const secondary = rest.slice(0, 3);
const more = rest.slice(3);

const pillarColors: Record<string, string> = {
	'Quantum Algorithms':   '#7c3aed',
	'Quantum Hardware':     '#0284c7',
	'Quantum Cryptography': '#059669',
	'AI Integrations':      '#d97706',
	'Future Tech':          '#dc2626',
};
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} ogImage="/og/home.png" />
		<style>
			/* ── Lead story ── */
			.lead {
				display: grid;
				grid-template-columns: 55% 1fr;
				gap: 2.5rem;
				align-items: center;
				padding: 2rem 0;
			}
			.lead-img {
				width: 100%;
				aspect-ratio: 16/10;
				object-fit: cover;
				border-radius: 2px;
			}
			.lead-body { display: flex; flex-direction: column; justify-content: center; }
			.lead-headline {
				font-size: 2.4em;
				line-height: 1.1;
				margin: 0.2em 0 0.5em;
				color: var(--text);
				text-decoration: none;
				display: block;
				transition: color 0.15s;
			}
			.lead-headline:hover { color: var(--accent); text-decoration: none; }
			.lead-desc {
				color: var(--text-muted);
				font-size: 0.95em;
				line-height: 1.6;
				margin: 0 0 0.75em;
			}
			.byline {
				font-size: 0.78em;
				color: var(--text-muted);
				display: flex;
				gap: 0.4em;
				align-items: center;
				flex-wrap: wrap;
			}
			.byline a { color: var(--text-muted); font-weight: 600; }
			.byline a:hover { color: var(--accent); text-decoration: underline; }
			.byline .sep { color: var(--border); }

			/* ── Section header ── */
			.section-header {
				display: flex;
				align-items: center;
				gap: 1em;
				margin: 2.5rem 0 1.25rem;
			}
			.section-header h2 {
				font-size: 0.68em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin: 0;
				color: var(--text);
				white-space: nowrap;
			}
			.section-header .rule-line {
				flex: 1;
				height: 1px;
				background: var(--border);
			}
			.section-header + .section-header {
				margin-top: 3rem;
			}

			/* ── Secondary grid ── */
			.secondary-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.75rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.secondary-item { display: flex; flex-direction: column; }
			.secondary-img {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
				border-radius: 2px;
				margin-bottom: 0.75rem;
				display: block;
				transition: opacity 0.2s;
			}
			.secondary-img:hover { opacity: 0.88; }
			.secondary-headline {
				font-size: 1.05em;
				font-weight: 700;
				line-height: 1.25;
				margin: 0.2em 0 0.4em;
				color: var(--text);
				text-decoration: none;
				display: block;
				transition: color 0.15s;
			}
			.secondary-headline:hover { color: var(--accent); text-decoration: none; }

			/* ── More list ── */
			.more-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.more-item {
				display: grid;
				grid-template-columns: 1fr auto;
				align-items: baseline;
				gap: 1.5rem;
				padding: 0.85rem 0;
				border-bottom: 1px solid var(--border);
			}
			.more-item:first-child { border-top: 1px solid var(--border); }
			.more-headline {
				font-size: 1em;
				font-weight: 700;
				margin: 0;
				color: var(--text);
				text-decoration: none;
				line-height: 1.3;
				transition: color 0.15s;
			}
			.more-headline:hover { color: var(--accent); text-decoration: none; }
			.more-meta {
				font-size: 0.75em;
				color: var(--text-muted);
				white-space: nowrap;
				text-align: right;
			}
			.more-author { display: block; font-weight: 600; }

			@media (max-width: 900px) {
				.lead { grid-template-columns: 1fr; }
				.secondary-grid { grid-template-columns: 1fr 1fr; }
			}
			@media (max-width: 600px) {
				.secondary-grid { grid-template-columns: 1fr; }
				.more-item { grid-template-columns: 1fr; }
				.more-meta { text-align: left; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Lead story -->
			{lead && (
				<section class="lead">
					<a href={`/articles/${lead.id}/`}>
						<Image
							class="lead-img"
							width={900}
							height={562}
							src={lead.data.heroImage || defaultHeroImage}
							alt={lead.data.title}
						/>
					</a>
					<div class="lead-body">
						{lead.data.pillar && (
							<p class="pillar">
								<a
									href={`/pillar/${lead.data.pillar.toLowerCase().replace(/\s+/g, '-')}/`}
									style={`color:${pillarColors[lead.data.pillar] ?? 'var(--accent)'}`}
								>{lead.data.pillar}</a>
							</p>
						)}
						<a class="lead-headline" href={`/articles/${lead.id}/`}>{lead.data.title}</a>
						<p class="lead-desc">{lead.data.description}</p>
						<p class="byline">
							<a href={`/author/${lead.data.author.toLowerCase().replace(/\s+/g, '-')}/`}>{lead.data.author}</a>
							<span class="sep">·</span>
							<FormattedDate date={lead.data.pubDate} />
						</p>
					</div>
				</section>
			)}

			<!-- Secondary stories -->
			{secondary.length > 0 && (
				<>
					<div class="section-header">
						<h2>Latest</h2>
						<span class="rule-line"></span>
					</div>
					<ul class="secondary-grid">
						{secondary.map((post) => (
							<li class="secondary-item">
								<a href={`/articles/${post.id}/`}>
									<Image
										class="secondary-img"
										width={480}
										height={270}
										src={post.data.heroImage || defaultHeroImage}
										alt={post.data.title}
									/>
								</a>
								{post.data.pillar && (
									<p class="pillar">
										<a
											href={`/pillar/${post.data.pillar.toLowerCase().replace(/\s+/g, '-')}/`}
											style={`color:${pillarColors[post.data.pillar] ?? 'var(--accent)'}`}
										>{post.data.pillar}</a>
									</p>
								)}
								<a class="secondary-headline" href={`/articles/${post.id}/`}>{post.data.title}</a>
								<p class="byline">
									<a href={`/author/${post.data.author.toLowerCase().replace(/\s+/g, '-')}/`}>{post.data.author}</a>
									<span class="sep">·</span>
									<FormattedDate date={post.data.pubDate} />
								</p>
							</li>
						))}
					</ul>
				</>
			)}

			<!-- More stories -->
			{more.length > 0 && (
				<>
					<div class="section-header">
						<h2>More Stories</h2>
						<span class="rule-line"></span>
					</div>
					<ul class="more-list">
						{more.map((post) => (
							<li class="more-item">
								<div>
									{post.data.pillar && (
										<p class="pillar" style="margin-bottom:0.2em">
											<a
												href={`/pillar/${post.data.pillar.toLowerCase().replace(/\s+/g, '-')}/`}
												style={`color:${pillarColors[post.data.pillar] ?? 'var(--accent)'}`}
											>{post.data.pillar}</a>
										</p>
									)}
									<a class="more-headline" href={`/articles/${post.id}/`}>{post.data.title}</a>
								</div>
								<div class="more-meta">
									<span class="more-author">{post.data.author}</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
							</li>
						))}
					</ul>
				</>
			)}
		</main>
		<Footer />
	</body>
</html>
