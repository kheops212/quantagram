---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, CONTACT_EMAIL } from '../consts';

const effectiveDate = 'July 2026';
---

<!doctype html>
<html lang="en" data-pagefind-ignore>
	<head>
		<BaseHead title={`Privacy Policy — ${SITE_TITLE}`} description={`Privacy policy for ${SITE_TITLE}, including how advertising and cookies are used.`} />
		<style>
			.page-head {
				padding: 2rem 0 1.25rem;
				border-bottom: 3px solid var(--text);
				margin-bottom: 2rem;
				max-width: 720px;
				margin-left: auto;
				margin-right: auto;
			}
			.page-head h1 { font-size: 2.4em; margin: 0 0 0.25em; }
			.page-head .updated { font-size: 0.82em; color: var(--text-muted); margin: 0; }

			.legal {
				max-width: 720px;
				margin: 0 auto;
				font-size: 1em;
				line-height: 1.75;
			}
			.legal h2 {
				font-size: 1.3em;
				margin: 2em 0 0.5em;
				padding-top: 1.25em;
				border-top: 1px solid var(--border);
			}
			.legal p { margin: 0 0 1.1em; color: var(--text); }
			.legal ul { margin: 0 0 1.1em; padding-left: 1.3em; }
			.legal li { margin: 0.3em 0; }
			.legal a { color: var(--accent); text-decoration: underline; }
			.legal a:hover { color: var(--accent-dark); }
			.note {
				font-size: 0.85em;
				color: var(--text-muted);
				border-left: 3px solid var(--border);
				padding: 0.5em 0 0.5em 1em;
				margin: 0 0 1.1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-head">
				<h1>Privacy Policy</h1>
				<p class="updated">Last updated: {effectiveDate}</p>
			</div>

			<div class="legal">
				<p>
					This Privacy Policy describes how {SITE_TITLE} (“we”, “us”, “our”) handles information
					when you visit this website. We aim to collect as little personal data as possible and to
					be transparent about the third-party services that operate on the site.
				</p>

				<h2>Information we collect</h2>
				<p>
					{SITE_TITLE} is a static publication and does not require you to create an account or submit
					personal information to read its content. We do not directly collect names, email addresses,
					or payment details unless you voluntarily provide them (for example, by subscribing to our
					newsletter or contacting us).
				</p>
				<p>
					Like most websites, our hosting provider and third-party services may automatically receive
					standard technical information — such as your IP address, browser type, device type, and the
					pages you visit — through server logs and cookies.
				</p>

				<h2>Cookies</h2>
				<p>
					Cookies are small text files stored on your device. We and our third-party partners may use
					cookies and similar technologies to remember your preferences (such as light or dark mode),
					understand how the site is used, and — where applicable — to deliver and measure advertising.
					You can control or delete cookies through your browser settings; disabling them may affect
					some site functionality.
				</p>

				<h2>Advertising</h2>
				<p>
					This site may display advertising served by <strong>Google AdSense</strong>, a third-party
					advertising service provided by Google LLC. When advertising is enabled:
				</p>
				<ul>
					<li>
						Third-party vendors, including Google, use cookies to serve ads based on your prior visits
						to this and other websites.
					</li>
					<li>
						Google’s use of advertising cookies enables it and its partners to serve ads to you based
						on your visits to this site and/or other sites on the Internet.
					</li>
					<li>
						You may opt out of personalised advertising by visiting
						<a href="https://www.google.com/settings/ads" target="_blank" rel="noopener noreferrer">Google Ads Settings</a>.
						You can also opt out of some third-party vendors’ use of cookies for personalised
						advertising at
						<a href="https://www.aboutads.info/choices/" target="_blank" rel="noopener noreferrer">aboutads.info</a>
						or
						<a href="https://www.youronlinechoices.eu/" target="_blank" rel="noopener noreferrer">youronlinechoices.eu</a>.
					</li>
					<li>
						For more information on how Google uses data when you use our partners’ sites or apps, see
						Google’s
						<a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener noreferrer">Privacy &amp; Terms</a>.
					</li>
				</ul>

				<h2>Consent (EEA, UK &amp; Switzerland)</h2>
				<p>
					If you are located in the European Economic Area, the United Kingdom, or Switzerland, we
					request your consent before any non-essential cookies (including advertising cookies) are set,
					using a consent management platform. You may withdraw or change your consent at any time via
					the privacy settings link presented on the site.
				</p>

				<h2>Analytics</h2>
				<p>
					We may use privacy-respecting analytics to understand aggregate traffic patterns. Any such
					data is used only in aggregate to improve the site and is not used to personally identify you.
				</p>

				<h2>Third-party links</h2>
				<p>
					Our articles link to external websites and resources. We are not responsible for the privacy
					practices of those third parties, and we encourage you to review their privacy policies.
				</p>

				<h2>Children’s privacy</h2>
				<p>
					This site is intended for a general, technical audience and is not directed at children under
					the age of 13. We do not knowingly collect personal information from children.
				</p>

				<h2>Changes to this policy</h2>
				<p>
					We may update this Privacy Policy from time to time. Changes will be reflected by the “Last
					updated” date above. Continued use of the site after changes constitutes acceptance of the
					revised policy.
				</p>

				<h2>Contact</h2>
				<p>
					If you have any questions about this Privacy Policy, you can reach us at
					<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
				</p>

				<p class="note">
					This policy is provided as a general template and does not constitute legal advice. You
					should review and adapt it — including your legal entity name, jurisdiction, contact details,
					and the specific ad/analytics services you use — before relying on it in production.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
