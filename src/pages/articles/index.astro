---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import defaultHeroImage from '../../assets/blog-placeholder-1.jpg';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pillarColors: Record<string, string> = {
	'Quantum Algorithms':   '#7c3aed',
	'Quantum Hardware':     '#0284c7',
	'Quantum Cryptography': '#059669',
	'AI Integrations':      '#d97706',
	'Future Tech':          '#dc2626',
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} ogImage="/og/articles.png" />
		<style>
			.page-header {
				padding: 2rem 0 1.25rem;
				border-bottom: 3px solid var(--text);
				margin-bottom: 0;
			}
			.page-header h1 {
				font-size: 2.5em;
				margin: 0;
			}

			/* Lead item */
			.lead-item {
				display: grid;
				grid-template-columns: 1fr 42%;
				gap: 2.5rem;
				align-items: center;
				padding: 2rem 0;
				border-bottom: 1px solid var(--border);
			}
			.lead-img {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
				border-radius: 2px;
				display: block;
			}
			.lead-headline {
				font-size: 1.9em;
				line-height: 1.15;
				color: var(--text);
				text-decoration: none;
				display: block;
				margin: 0.2em 0 0.5em;
				transition: color 0.15s;
			}
			.lead-headline:hover { color: var(--accent); text-decoration: none; }
			.lead-desc { color: var(--text-muted); font-size: 0.92em; line-height: 1.6; margin: 0 0 0.75em; }

			/* Article list */
			.article-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.article-item {
				display: grid;
				grid-template-columns: 1fr 200px;
				gap: 1.5rem;
				align-items: start;
				padding: 1.25rem 0;
				border-bottom: 1px solid var(--border);
			}
			.article-headline {
				font-size: 1.1em;
				font-weight: 700;
				line-height: 1.25;
				color: var(--text);
				text-decoration: none;
				display: block;
				margin: 0.2em 0 0.4em;
				transition: color 0.15s;
			}
			.article-headline:hover { color: var(--accent); text-decoration: none; }
			.article-img {
				width: 200px;
				height: 120px;
				object-fit: cover;
				border-radius: 2px;
				display: block;
				transition: opacity 0.2s;
			}
			.article-img:hover { opacity: 0.88; }

			.byline {
				font-size: 0.78em;
				color: var(--text-muted);
				display: flex;
				gap: 0.4em;
				align-items: center;
				flex-wrap: wrap;
			}
			.byline a { color: var(--text-muted); font-weight: 600; }
			.byline a:hover { color: var(--accent); text-decoration: underline; }
			.byline .sep { color: var(--border); }
			.desc { color: var(--text-muted); font-size: 0.88em; line-height: 1.5; margin: 0.35em 0 0; }

			@media (max-width: 768px) {
				.lead-item { grid-template-columns: 1fr; }
				.article-item { grid-template-columns: 1fr; }
				.article-img { width: 100%; height: auto; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>All Articles</h1>
			</div>

			{posts.length > 0 && (() => {
				const [lead, ...rest] = posts;
				return (
					<>
						<!-- Lead -->
						<div class="lead-item">
							<div>
								{lead.data.pillar && (
									<p class="pillar">
										<a
											href={`/pillar/${lead.data.pillar.toLowerCase().replace(/\s+/g, '-')}/`}
											style={`color:${pillarColors[lead.data.pillar] ?? 'var(--accent)'}`}
										>{lead.data.pillar}</a>
									</p>
								)}
								<a class="lead-headline" href={`/articles/${lead.id}/`}>{lead.data.title}</a>
								<p class="lead-desc">{lead.data.description}</p>
								<p class="byline">
									<a href={`/author/${lead.data.author.toLowerCase().replace(/\s+/g, '-')}/`}>{lead.data.author}</a>
									<span class="sep">·</span>
									<FormattedDate date={lead.data.pubDate} />
								</p>
							</div>
							<a href={`/articles/${lead.id}/`}>
								<Image
									class="lead-img"
									width={480}
									height={270}
									src={lead.data.heroImage || defaultHeroImage}
									alt={lead.data.title}
								/>
							</a>
						</div>

						<!-- Rest -->
						<ul class="article-list">
							{rest.map((post) => (
								<li class="article-item">
									<div>
										{post.data.pillar && (
											<p class="pillar">
												<a
													href={`/pillar/${post.data.pillar.toLowerCase().replace(/\s+/g, '-')}/`}
													style={`color:${pillarColors[post.data.pillar] ?? 'var(--accent)'}`}
												>{post.data.pillar}</a>
											</p>
										)}
										<a class="article-headline" href={`/articles/${post.id}/`}>{post.data.title}</a>
										<p class="byline">
											<a href={`/author/${post.data.author.toLowerCase().replace(/\s+/g, '-')}/`}>{post.data.author}</a>
											<span class="sep">·</span>
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="desc">{post.data.description}</p>
									</div>
									<a href={`/articles/${post.id}/`}>
										<Image
											class="article-img"
											width={240}
											height={144}
											src={post.data.heroImage || defaultHeroImage}
											alt={post.data.title}
										/>
									</a>
								</li>
							))}
						</ul>
					</>
				);
			})()}
		</main>
		<Footer />
	</body>
</html>
