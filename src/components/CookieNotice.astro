---
/**
 * Dismissible cookie notice bar. Informational — appears once, remembers the
 * dismissal in localStorage. For full GDPR/AdSense consent in the EEA/UK,
 * pair this with a Google-certified CMP (Privacy & messaging / Funding Choices).
 */
import { COOKIE_NOTICE } from '../consts';
---

{COOKIE_NOTICE && (
	<div id="cookie-notice" class="cookie-notice" role="region" aria-label="Cookie notice" hidden data-pagefind-ignore>
		<div class="cn-icon" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
				<path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5Z"/>
				<circle cx="9" cy="10" r="1" fill="currentColor" stroke="none"/>
				<circle cx="14" cy="15" r="1" fill="currentColor" stroke="none"/>
				<circle cx="8" cy="15" r="0.75" fill="currentColor" stroke="none"/>
			</svg>
		</div>
		<p class="cn-text">
			We use cookies for essential site functionality and, where enabled, advertising and
			analytics. See our <a href="/privacy">Privacy Policy</a>.
		</p>
		<div class="cn-actions">
			<a class="cn-btn cn-secondary" href="/privacy">Learn more</a>
			<button id="cn-accept" class="cn-btn cn-accept" type="button">Got it</button>
		</div>
	</div>
)}

<style>
	.cookie-notice {
		position: fixed;
		left: 1rem;
		right: 1rem;
		bottom: 1rem;
		z-index: 1500;
		max-width: 760px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		background: var(--bg);
		border: 1px solid var(--border);
		border-top: 3px solid var(--accent);
		border-radius: 10px;
		padding: 0.95rem 1.2rem;
		box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.28), 0 2px 8px -2px rgba(0, 0, 0, 0.12);
		animation: cn-rise 0.28s cubic-bezier(0.16, 1, 0.3, 1);
	}
	/* Explicitly win over `.cookie-notice { display:flex }` so `hidden` actually
	   hides the bar (equal-specificity author rule would otherwise override the
	   UA `[hidden]{display:none}` rule). */
	.cookie-notice[hidden] { display: none !important; }
	/* Smooth fade-out applied just before removal. */
	.cookie-notice.cn-dismissing {
		animation: cn-fall 0.22s ease forwards;
		pointer-events: none;
	}
	@keyframes cn-rise {
		from { transform: translateY(16px); opacity: 0; }
		to   { transform: translateY(0); opacity: 1; }
	}
	@keyframes cn-fall {
		from { transform: translateY(0); opacity: 1; }
		to   { transform: translateY(16px); opacity: 0; }
	}
	.cn-icon {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 50%;
		background: var(--bg-alt);
		color: var(--accent);
	}
	.cn-text {
		margin: 0;
		font-size: 0.84em;
		line-height: 1.5;
		color: var(--text-muted);
		flex: 1 1 300px;
	}
	.cn-text a { color: var(--accent); text-decoration: underline; }
	.cn-actions {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		flex-shrink: 0;
	}
	.cn-btn {
		font-size: 0.8em;
		font-weight: 600;
		padding: 0.55em 1.15em;
		border-radius: 6px;
		cursor: pointer;
		font-family: inherit;
		text-decoration: none;
		white-space: nowrap;
		border: 1px solid var(--border);
		transition: background 0.15s, color 0.15s, border-color 0.15s;
	}
	.cn-secondary { color: var(--text-muted); background: transparent; }
	.cn-secondary:hover { color: var(--text); border-color: var(--text); text-decoration: none; }
	.cn-accept { background: var(--text); color: var(--bg); border-color: var(--text); }
	.cn-accept:hover { background: var(--accent); border-color: var(--accent); color: #fff; }

	@media (max-width: 560px) {
		.cookie-notice { gap: 0.75rem; padding: 0.9rem 1rem; }
		.cn-icon { display: none; }
		.cn-actions { flex: 1 1 100%; justify-content: flex-end; }
	}
	@media (prefers-reduced-motion: reduce) {
		.cookie-notice, .cookie-notice.cn-dismissing { animation: none; }
	}
</style>

<script>
	const KEY = 'cookie-consent';
	const el = document.getElementById('cookie-notice');
	if (el) {
		let seen = false;
		try { seen = !!localStorage.getItem(KEY); } catch (e) {}
		if (!seen) el.hidden = false;

		const dismiss = () => {
			try { localStorage.setItem(KEY, '1'); } catch (e) {}
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (reduce) { el.hidden = true; return; }
			el.classList.add('cn-dismissing');
			el.addEventListener('animationend', () => { el.hidden = true; }, { once: true });
			// Safety fallback in case animationend doesn't fire.
			setTimeout(() => { el.hidden = true; }, 400);
		};

		document.getElementById('cn-accept')?.addEventListener('click', dismiss);
	}
</script>
