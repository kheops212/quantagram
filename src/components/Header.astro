---
import { SITE_TITLE } from '../consts';
import Search from './Search.astro';
import HeaderLink from './HeaderLink.astro';

const today = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---

<header>
	<!-- Top bar: date + site title -->
	<div class="top-bar">
		<span class="dateline">{today}</span>
		<a class="site-title" href="/">{SITE_TITLE}</a>
		<div class="top-bar-right">
			<span class="search-wrap"><Search /></span>
			<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
				<svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
				<svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
			</button>
		</div>
	</div>

	<hr class="rule-thick" />

	<!-- Nav bar -->
	<nav>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/articles">Articles</HeaderLink>
			<HeaderLink href="/newsletter">Newsletter</HeaderLink>
			<HeaderLink href="/glossary">Glossary</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<div class="dropdown">
				<a href="/pillars" class="dropdown-toggle">Pillars &#9662;</a>
				<ul class="dropdown-menu">
					<li><a href="/pillars">All Pillars</a></li>
					<li class="separator"></li>
					<li><a href="/pillar/quantum-algorithms">Quantum Algorithms</a></li>
					<li><a href="/pillar/quantum-hardware">Quantum Hardware</a></li>
					<li><a href="/pillar/quantum-cryptography">Quantum Cryptography</a></li>
					<li><a href="/pillar/ai-integrations">AI Integrations</a></li>
					<li><a href="/pillar/future-tech">Future Tech</a></li>
				</ul>
			</div>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/company/quantagram" target="_blank" rel="noopener" aria-label="LinkedIn">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
			</a>
			<a href="https://github.com" target="_blank" aria-label="GitHub">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
			</a>
		</div>
	</nav>
	<hr />
</header>

<style>
	header {
		background: var(--bg);
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid var(--border);
	}

	/* Top bar */
	.top-bar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: 0.6em 1.5em 0.5em;
		gap: 1em;
		max-width: 1200px;
		margin: 0 auto;
	}
	.dateline {
		font-size: 0.72em;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}
	.site-title {
		font-size: 1.5em;
		font-weight: 800;
		letter-spacing: -0.03em;
		color: var(--text);
		text-decoration: none;
		text-align: center;
		white-space: nowrap;
	}
	.site-title:hover { text-decoration: none; color: var(--accent); }
	.top-bar-right {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 0.6em;
	}

	/* Theme toggle */
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 4px;
		background: var(--bg);
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.theme-toggle:hover { color: var(--accent); border-color: var(--accent); }
	.theme-toggle .icon-moon { display: none; }
	.theme-toggle .icon-sun { display: block; }
	:root[data-theme="dark"] .theme-toggle .icon-moon { display: block; }
	:root[data-theme="dark"] .theme-toggle .icon-sun { display: none; }

	/* Rule */
	.rule-thick {
		border: none;
		border-top: 3px solid var(--text);
		margin: 0;
	}

	/* Nav */
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		max-width: 1200px;
		margin: 0 auto;
		gap: 1em;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.1em;
	}
	.nav-links :global(a) {
		padding: 0.55em 0.85em;
		font-size: 0.82em;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--accent);
		text-decoration: none;
	}

	/* Dropdown */
	.dropdown { position: relative; }
	.dropdown-toggle {
		padding: 0.55em 0.85em;
		font-size: 0.82em;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		cursor: pointer;
		display: inline-block;
		transition: color 0.15s, border-color 0.15s;
	}
	.dropdown-toggle:hover,
	.dropdown.open .dropdown-toggle {
		color: var(--accent);
		border-bottom-color: var(--accent);
		text-decoration: none;
	}
	.dropdown-menu {
		position: absolute;
		top: calc(100% + 6px);
		left: 0;
		opacity: 0;
		visibility: hidden;
		transform: translateY(6px);
		transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
		list-style: none;
		margin: 0;
		padding: 0.4em 0;
		background: var(--bg);
		border: 1px solid var(--border);
		border-top: 2px solid var(--text);
		min-width: 200px;
		z-index: 200;
	}
	.dropdown:hover .dropdown-menu,
	.dropdown.open .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.dropdown-menu li a {
		display: block;
		padding: 0.45em 1.1em;
		font-size: 0.85em;
		font-weight: 500;
		color: var(--text);
		text-decoration: none;
		transition: background 0.1s, color 0.1s;
	}
	.dropdown-menu li a:hover {
		background: var(--bg-alt);
		color: var(--accent);
		text-decoration: none;
	}
	.dropdown-menu .separator {
		height: 1px;
		background: var(--border);
		margin: 0.3em 0;
	}

	/* Social */
	.social-links { display: flex; gap: 0.75em; align-items: center; }
	.social-links a { color: var(--text-muted); display: flex; align-items: center; transition: color 0.15s; }
	.social-links a:hover { color: var(--accent); text-decoration: none; }

	@media (max-width: 768px) {
		.top-bar { grid-template-columns: 1fr; text-align: center; gap: 0.25em; padding: 0.5em 1em; }
		.dateline, .search-wrap { display: none; }
		.top-bar-right { justify-content: center; }
		.site-title { font-size: 1.2em; }
		nav { flex-wrap: wrap; padding: 0 0.5em; }
		.nav-links :global(a), .dropdown-toggle { padding: 0.5em 0.5em; font-size: 0.78em; }
		.social-links { display: none; }
		.dropdown-menu { position: static; opacity: 1; visibility: visible; transform: none; border: none; border-top: 1px solid var(--border); }
	}
</style>

<script>
	document.querySelectorAll('.dropdown').forEach((dropdown) => {
		const toggle = dropdown.querySelector('.dropdown-toggle');
		if (toggle) {
			toggle.addEventListener('click', (e) => {
				if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
					e.preventDefault();
					dropdown.classList.toggle('open');
				}
			});
		}
	});

	// Dark-mode toggle
	const themeToggle = document.getElementById('theme-toggle');
	themeToggle?.addEventListener('click', () => {
		const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
		document.documentElement.dataset.theme = next;
		try { localStorage.setItem('theme', next); } catch (e) {}
	});
</script>
