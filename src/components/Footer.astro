---
import ScrollToTop from './ScrollToTop.astro';
import CookieNotice from './CookieNotice.astro';
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-grid">
			<div class="footer-brand">
				<a class="brand-name" href="/">{SITE_TITLE}</a>
				<p class="tagline">Exploring the intersection of Quantum Computing and AI.</p>
			</div>
			<nav class="footer-nav">
				<span class="nav-label">Sections</span>
				<a href="/pillar/quantum-algorithms">Quantum Algorithms</a>
				<a href="/pillar/quantum-hardware">Quantum Hardware</a>
				<a href="/pillar/quantum-cryptography">Quantum Cryptography</a>
				<a href="/pillar/ai-integrations">AI Integrations</a>
				<a href="/pillar/future-tech">Future Tech</a>
			</nav>
			<nav class="footer-nav">
				<span class="nav-label">Publication</span>
				<a href="/">Home</a>
				<a href="/articles">All Articles</a>
				<a href="/pillars">Browse Sections</a>
				<a href="/newsletter">Newsletter</a>
				<a href="/about">About</a>
				<a href="/privacy">Privacy Policy</a>
				<a href="/rss.xml">RSS Feed</a>
			</nav>
		</div>
		<div class="footer-bottom">
			<p class="copyright">&copy; {year} {SITE_TITLE}. All rights reserved.</p>
			<nav class="footer-legal">
				<a href="/privacy">Privacy</a>
				<button id="manage-consent" type="button" hidden>Privacy settings</button>
			</nav>
		</div>
	</div>
</footer>
<ScrollToTop />
<CookieNotice />

<style>
	footer {
		background: var(--bg-alt);
		border-top: 3px solid var(--text);
		margin-top: 4rem;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 2rem 1.5em 1.5rem;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2rem;
		padding-bottom: 2rem;
	}
	.brand-name {
		font-size: 1.1em;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text);
		text-decoration: none;
		display: block;
		margin-bottom: 0.5em;
	}
	.brand-name:hover { color: var(--accent); text-decoration: none; }
	.tagline {
		font-size: 0.85em;
		color: var(--text-muted);
		line-height: 1.5;
		margin: 0;
	}
	.footer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.nav-label {
		font-size: 0.68em;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text);
		margin-bottom: 0.35em;
	}
	.footer-nav a {
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-nav a:hover { color: var(--accent); text-decoration: none; }
	.footer-bottom {
		border-top: 1px solid var(--border);
		padding-top: 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.copyright {
		font-size: 0.78em;
		color: var(--text-muted);
		margin: 0;
	}
	.footer-legal {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.footer-legal a,
	.footer-legal button {
		font-size: 0.78em;
		color: var(--text-muted);
		text-decoration: none;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		font-family: inherit;
	}
	.footer-legal a:hover,
	.footer-legal button:hover { color: var(--accent); text-decoration: underline; }

	@media (max-width: 700px) {
		.footer-grid { grid-template-columns: 1fr 1fr; }
		.footer-brand { grid-column: 1 / -1; }
	}
	@media (max-width: 480px) {
		.footer-grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	// "Privacy settings" — only shown when a Google-certified consent management
	// platform (e.g. Google's Privacy & messaging / Funding Choices) is present.
	// Lets EEA/UK visitors reopen the consent dialog to change their choice.
	const consentBtn = document.getElementById('manage-consent');
	if (consentBtn) {
		const gfc = (window as any).googlefc;
		if (gfc && typeof gfc.showRevocationMessage === 'function') {
			consentBtn.hidden = false;
			consentBtn.addEventListener('click', () => gfc.showRevocationMessage());
		}
	}
</script>
