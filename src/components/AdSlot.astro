---
/**
 * Google AdSense ad unit.
 *
 * Renders NOTHING unless all of these hold:
 *   1. ADSENSE_CLIENT is set in consts.ts (your pub-id)
 *   2. ADSENSE_ENABLED is true in consts.ts
 *   3. a `slot` id is passed (the ad unit id from your AdSense dashboard)
 *
 * A fixed min-height is reserved so ads never cause layout shift (CLS).
 */
import { ADSENSE_CLIENT, ADSENSE_ENABLED } from '../consts';

interface Props {
	/** Ad unit slot ID from the AdSense dashboard */
	slot?: string;
	/** AdSense format: 'auto', 'fluid', 'rectangle', etc. */
	format?: string;
	/** Allow full-width responsive resizing */
	responsive?: boolean;
	/** Reserved height (px) to prevent layout shift before the ad loads */
	minHeight?: number;
}

const { slot = '', format = 'auto', responsive = true, minHeight = 280 } = Astro.props;
const active = Boolean(ADSENSE_CLIENT) && ADSENSE_ENABLED && Boolean(slot);
---

{active && (
	<aside class="ad-slot" style={`min-height:${minHeight}px`} aria-label="Advertisement" data-pagefind-ignore>
		<span class="ad-label">Advertisement</span>
		<ins
			class="adsbygoogle"
			style="display:block"
			data-ad-client={ADSENSE_CLIENT}
			data-ad-slot={slot}
			data-ad-format={format}
			data-full-width-responsive={responsive ? 'true' : 'false'}
		></ins>
		<script is:inline>
			(window.adsbygoogle = window.adsbygoogle || []).push({});
		</script>
	</aside>
)}

<style>
	.ad-slot {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-width: 680px;
		margin: 2.5rem auto;
		padding: 0.5rem 0;
		overflow: hidden;
	}
	.ad-label {
		font-size: 0.62em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 0.5rem;
		opacity: 0.7;
	}
	.ad-slot :global(.adsbygoogle) {
		width: 100%;
	}
</style>
